# ═══════════════════════════════════════════════
#  VENDI POS — Backend Environment Variables
# ═══════════════════════════════════════════════
#
# Copy to .env and fill in your values
# On Render/Railway: set these in environment settings

# ── Database (Railway MySQL) ──
DB_HOST=your-db-host.railway.app
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=railway
DB_PORT=3306

# ── Security (CHANGE THESE IN PRODUCTION!) ──
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
STALL_SECRET=change-this-to-another-long-random-string

# ── App ──
PORT=5000
NODE_ENV=production

# ── CORS: your frontend URL (no trailing slash) ──
FRONTEND_URL=https://your-frontend.vercel.app
